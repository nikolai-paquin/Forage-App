{
  "manifest_version": 3,
  "name": "Forage — Save to library",
  "version": "0.1.0",
  "description": "Forage the current page, image, link, or selection into your Forage library.",
  "icons": { "128": "icon-128.png" },
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "128": "icon-128.png" }
  },
  "background": { "service_worker": "background.js" },
  "permissions": ["contextMenus", "activeTab", "tabs", "scripting"]
}
