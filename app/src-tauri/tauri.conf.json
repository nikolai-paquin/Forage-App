{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Forage",
  "version": "0.1.0",
  "identifier": "com.nikolaipaquin.forage",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Forage",
        "width": 1240,
        "height": 820,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "maximizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
